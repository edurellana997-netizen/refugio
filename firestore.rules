rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Una sala es privada: solo el anfitrión y el invitado pueden leerla/escribirla.
    match /rooms/{roomId} {
      function isMember() {
        return request.auth != null &&
          (resource.data.hostUid == request.auth.uid ||
           resource.data.guestUid == request.auth.uid);
      }
      function joiningEmptySlot() {
        // Permite que un segundo usuario reclame el lugar de invitado vacío.
        return request.auth != null &&
          resource.data.guestUid == null &&
          request.resource.data.guestUid == request.auth.uid;
      }

      allow create: if request.auth != null
                    && request.resource.data.hostUid == request.auth.uid;
      allow read:   if isMember() || (request.auth != null && resource.data.guestUid == null);
      allow update: if isMember() || joiningEmptySlot();
      allow delete: if false;

      // Subcolecciones: participantes, mensajes y señalización WebRTC.
      // Requieren ser miembro de la sala padre.
      match /{sub=**} {
        function memberOfRoom() {
          let room = get(/databases/$(database)/documents/rooms/$(roomId)).data;
          return request.auth != null &&
            (room.hostUid == request.auth.uid || room.guestUid == request.auth.uid);
        }
        allow read, write: if memberOfRoom();
      }
    }
  }
}
